#!/bin/bash
set -euo pipefail

DXNN_DIR="/home/ubuntu/dxnn-trader"

checkpoint() {
    echo "Manual checkpoint - files will be uploaded directly from $DXNN_DIR"
    echo "Checkpoint ready for S3 upload"
    exit 0
}

upload_to_s3() {
    # Trigger S3 upload directly from filesystem (no checkpoint needed)
    echo "Triggering S3 upload from $DXNN_DIR"
    
    # Set environment variables for finalize script
    export COMPLETION_STATUS="manual"
    export EXIT_CODE="0"
    export POPULATION_ID="${POPULATION_ID:-manual_upload}"
    export LINEAGE_ID="${LINEAGE_ID:-manual}"
    
    # Call finalize script which will upload directly
    if [[ -x /usr/local/bin/finalize_run.sh ]]; then
        /usr/local/bin/finalize_run.sh
        echo "S3 upload completed"
        exit 0
    else
        echo "Error: finalize_run.sh not found"
        exit 1
    fi
}

restore() {
    # Send restore command to the running tmux session as ubuntu user
    if ! sudo -u ubuntu tmux send-keys -t trader 'exp_runner:maybe_restore().' Enter; then
        echo "Failed to send restore command to tmux"
        exit 10
    fi
    
    # Wait a moment for the command to execute
    sleep 2
    
    echo "Restore command sent successfully"
    exit 0
}

case "${1:-}" in
    checkpoint) checkpoint ;;
    upload) upload_to_s3 ;;
    restore) restore ;;
    *) echo "Usage: $0 {checkpoint|upload|restore}" >&2; exit 1 ;;
esac
